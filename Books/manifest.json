{
  "id": "nexus.books",
  "displayName": "Books",
  "version": "0.1.8",
  "apiVersion": 1,
  "schemaVersion": 1,
  "description": "Biblioteca local PDF-first con progreso simple, detalle por item y busqueda derivada.",
  "author": "NEW-NEXUS",
  "entrypoints": {
    "backend": "./dist/backend.cjs",
    "renderer": "./dist/renderer.js"
  },
  "contributes": {
    "engines": [
      {
        "id": "nexus.books.document",
        "displayName": "Books",
        "extensions": ["pdf"],
        "mimeTypes": ["application/pdf"],
        "priority": 330,
        "supportsGlobalMatch": false,
        "supportsFolderAssignments": true
      }
    ],
    "views": [],
    "sideToolbar": [],
    "frameMenu": [],
    "fileExplorerHeader": []
  }
}

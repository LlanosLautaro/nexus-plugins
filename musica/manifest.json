{
  "id": "nexus.musica",
  "displayName": "Musica",
  "version": "0.1.0",
  "apiVersion": 1,
  "schemaVersion": 1,
  "description": "Indexacion, metadata editable e IPC para audio dentro de Nexus.",
  "author": "NEW-NEXUS",
  "entrypoints": {
    "backend": "./dist/backend.cjs",
    "renderer": "./dist/renderer.js"
  },
  "contributes": {
    "settings": {
      "schema": "./settings/schema.json",
      "defaults": "./settings/defaults.json"
    },
    "engines": [
      {
        "id": "nexus.musica.audio",
        "displayName": "Musica",
        "extensions": ["mp3", "wav", "ogg", "flac", "m4a", "aac", "opus", "oga"],
        "mimeTypes": ["audio/*"],
        "priority": 320,
        "supportsGlobalMatch": false,
        "supportsFolderAssignments": true
      }
    ],
    "views": [],
    "sideToolbar": [],
    "frameMenu": [],
    "fileExplorerHeader": []
  }
}
